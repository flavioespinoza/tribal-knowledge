{
  "name": "tribal-knowledge",
  "version": "1.0.0",
  "description": "TypeScript file watcher that OCRs Slack screenshots via Gemini Vision, structures via Gemini 2.5 Flash, and writes markdown. Engine runs from this repo, output goes to target project.",
  "type": "module",
  "main": "dist/watcher.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/watcher.js",
    "dev": "tsx src/watcher.ts"
  },
