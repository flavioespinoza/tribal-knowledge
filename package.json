  "dependencies": {
    "@google/genai": "^1.0.0",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^22.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
